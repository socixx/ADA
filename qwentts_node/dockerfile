FROM python:3.11-slim

WORKDIR /app

# FIX: Add sox and libsox-dev dependencies so the underlying audio tokenizer can resample audio
RUN apt-get update && apt-get install -y ffmpeg git build-essential sox libsox-dev && rm -rf /var/lib/apt/lists/*

# Install the stable PyTorch 2.5.1 + CUDA 12.4 dependencies
RUN pip install --no-cache-dir torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 --index-url https://download.pytorch.org/whl/cu124

# Install standard dependencies
RUN pip install --no-cache-dir fastapi uvicorn pydantic numpy transformers accelerate

# Install the ultra-fast streaming library directly
RUN pip install --no-cache-dir git+https://github.com/andimarafioti/faster-qwen3-tts.git

# Copy local code context
COPY server.py /app/server.py

EXPOSE 8000
CMD ["python", "server.py"]